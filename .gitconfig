[user]
	name = Hidekazu Kobayashi
	email = kobahide789@gmail.com
[core]
	excludesfile = ~/.gitignore
	pager = less -R
[color]
	ui = auto
[alias]
	st = status
	co = checkout
	ca = commit -a
	ps = push
	lg = log --stat --graph --decorate=full
	pl = pull
	delete-merged-branches = !git branch --merged | grep -v \\* | xargs -I % git branch -d %
  aicommit = "!f() { \
              COMMITMSG=$(claude --model haiku -p \
                'Generate ONLY a one-line Git commit message in English, \
                using imperative mood, summarizing what was changed and why, \
                based strictly on the contents of `git diff --cached`. \
                Do not add explanation or a body. \
                The output MUST be 50 characters or fewer (including spaces). \
                If necessary, rewrite to fit within the limit. \
                Output only the commit summary line.'); \
              git commit -m \"$COMMITMSG\" -e; \
              }; f"
[push]
	default = simple
[include]
	path = .gitconfig.local
[init]
	defaultBranch = main
